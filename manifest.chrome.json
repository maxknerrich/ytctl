{
  "manifest_version": 3,
  "name": "ytctl",
  "version": "1.0.0",
  "minimum_chrome_version": "110",
  "description": "Better controls for YouTube, starting with playback-speed hotkeys, profiles, and per-creator rules.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "*://youtube.com/*",
    "*://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://youtube.com/*",
        "*://www.youtube.com/*"
      ],
      "js": ["shared.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "increase": {
      "suggested_key": { "default": "Alt+Shift+Up" },
      "description": "Increase playback speed"
    },
    "decrease": {
      "suggested_key": { "default": "Alt+Shift+Down" },
      "description": "Decrease playback speed"
    },
    "reset": {
      "suggested_key": { "default": "Alt+Shift+0" },
      "description": "Reset playback speed"
    },
    "_execute_action": {
      "suggested_key": { "default": "Alt+Shift+P" },
      "description": "Open the speed profiles popup"
    },
    "profile1": { "description": "Activate profile slot 1" },
    "profile2": { "description": "Activate profile slot 2" },
    "profile3": { "description": "Activate profile slot 3" },
    "profile4": { "description": "Activate profile slot 4" },
    "profile5": { "description": "Activate profile slot 5" },
    "profile6": { "description": "Activate profile slot 6" },
    "profile7": { "description": "Activate profile slot 7" },
    "profile8": { "description": "Activate profile slot 8" },
    "profile9": { "description": "Activate profile slot 9" }
  },
  "action": {
    "default_title": "ytctl",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
